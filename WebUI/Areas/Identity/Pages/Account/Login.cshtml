@page
@model LoginModel

@{
    ViewData["Title"] = "Login";
    Layout = null; // Full custom layout for login page
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login — DIU Department of Law</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        body {
            background: linear-gradient(135deg, #004d26 0%, #006633 50%, #008844 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
        }

        .login-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.25);
            overflow: hidden;
            width: 100%;
            max-width: 440px;
        }

        .login-header {
            background: linear-gradient(135deg, #004d26, #006633);
            color: white;
            padding: 32px 32px 28px;
            text-align: center;
        }

        .logo-circle {
            width: 80px;
            height: 80px;
            background: rgba(255,255,255,0.15);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.4rem;
            margin: 0 auto 14px;
            border: 2px solid rgba(255,255,255,0.3);
        }

        .login-header h4 {
            font-weight: 800;
            margin: 0;
            font-size: 1.3rem;
        }

        .login-header p {
            margin: 4px 0 0;
            opacity: 0.8;
            font-size: 0.85rem;
        }

        .login-body {
            padding: 32px;
        }

        .form-control {
            border-radius: 10px;
            border: 1.5px solid #e0e0e0;
            padding: 11px 16px;
            font-size: 0.93rem;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

            .form-control:focus {
                border-color: #006633;
                box-shadow: 0 0 0 3px rgba(0,102,51,0.12);
            }

        .form-label {
            font-weight: 600;
            color: #333;
            font-size: 0.88rem;
            margin-bottom: 5px;
        }

        .btn-login {
            background: linear-gradient(135deg, #006633, #004d26);
            color: white;
            border: none;
            border-radius: 10px;
            padding: 12px;
            font-weight: 700;
            font-size: 1rem;
            width: 100%;
            transition: all 0.2s;
            letter-spacing: 0.3px;
        }

            .btn-login:hover {
                background: linear-gradient(135deg, #004d26, #003319);
                color: white;
                transform: translateY(-1px);
                box-shadow: 0 4px 14px rgba(0,102,51,0.3);
            }

        .divider {
            text-align: center;
            margin: 18px 0;
            color: #bbb;
            font-size: 0.85rem;
        }

        .link-register {
            color: #006633;
            font-weight: 600;
            text-decoration: none;
        }

            .link-register:hover {
                text-decoration: underline;
            }

        .footer-note {
            background: #f8faf9;
            border-top: 1px solid #eee;
            padding: 14px 32px;
            text-align: center;
            font-size: 0.78rem;
            color: #999;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <!-- Header -->
        <div class="login-header">
            <div class="logo-circle">⚖️</div>
            <h4>Department of Law</h4>
            <p>Daffodil International University</p>
        </div>

        <!-- Body -->
        <div class="login-body">
            <h5 class="fw-bold mb-1" style="color:#1a1a2e;">Welcome back</h5>
            <p class="text-muted mb-4" style="font-size:0.88rem;">Sign in to access LexBot and your department resources</p>

            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 px-3 mb-3" style="font-size:0.88rem;border-radius:8px;" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label">
                        <i class="fas fa-envelope me-1" style="color:#006633;"></i>Email Address
                    </label>
                    <input asp-for="Input.Email" class="form-control" autocomplete="username"
                           placeholder="you@diu.edu.bd" aria-required="true" />
                    <span asp-validation-for="Input.Email" class="text-danger" style="font-size:0.82rem;"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label">
                        <i class="fas fa-lock me-1" style="color:#006633;"></i>Password
                    </label>
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password"
                           placeholder="Enter your password" aria-required="true" />
                    <span asp-validation-for="Input.Password" class="text-danger" style="font-size:0.82rem;"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="Input.RememberMe" style="accent-color:#006633;" />
                        <label asp-for="Input.RememberMe" class="form-check-label" style="font-size:0.87rem;">Remember me</label>
                    </div>
                    <a asp-page="./ForgotPassword" style="font-size:0.85rem;color:#006633;">Forgot password?</a>
                </div>

                <button id="login-submit" type="submit" class="btn-login">
                    <i class="fas fa-sign-in-alt me-2"></i>Sign In
                </button>
            </form>

            <div class="divider">— or —</div>

            <div class="text-center">
                <span style="font-size:0.88rem;color:#666;">Don't have an account?</span>
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="link-register ms-1">
                    Register here
                </a>
            </div>
        </div>

        <div class="footer-note">
            <i class="fas fa-shield-alt me-1"></i>
            Secure login · DIU Department of Law Management System
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
