<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — DIU Department of Law</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-md navbar-diu">
            <div class="container-fluid px-3">

                <!-- Brand with SVG logo placeholder -->
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <div style="width:38px;height:38px;background:white;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <span style="color:#006633;font-weight:900;font-size:1rem;">⚖</span>
                    </div>
                    <div>
                        <div style="font-size:0.95rem;line-height:1.1;">Department of Law</div>
                        <div style="font-size:0.72rem;opacity:0.8;font-weight:400;">Daffodil International University</div>
                    </div>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain"
                        aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMain">
                    @using Microsoft.AspNetCore.Identity
                    @inject SignInManager<IdentityUser> SignInManager
                    @inject UserManager<IdentityUser> UserManager

                    <ul class="navbar-nav me-auto mb-2 mb-md-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home me-1"></i>Home
                            </a>
                        </li>
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="LawChat" asp-action="Index">
                                    <i class="fas fa-robot me-1"></i>LexBot
                                </a>
                            </li>
                            if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="PersonalDetails" asp-action="Index">
                                        <i class="fas fa-users me-1"></i>Faculty Details
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto align-items-center gap-2">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item">
                                <span class="nav-link navbar-user-badge">
                                    <i class="fas fa-user-circle me-1"></i>@User.Identity.Name
                                </span>
                            </li>
                            <li class="nav-item">
                                <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="d-inline">
                                    <button type="submit" class="btn-logout border-0 cursor-pointer">
                                        <i class="fas fa-sign-out-alt me-1"></i>Logout
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/Identity/Account/Login">
                                    <i class="fas fa-sign-in-alt me-1"></i>Login
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/Identity/Account/Register">
                                    <i class="fas fa-user-plus me-1"></i>Register
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-4 py-3">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-diu-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-diu">
        <div class="container-fluid px-4 d-flex justify-content-between align-items-center">
            <span>
                <i class="fas fa-balance-scale me-1"></i>
                &copy; @DateTime.Now.Year Department of Law — Daffodil International University
            </span>
            <span>
                <a href="https://daffodilvarsity.edu.bd" target="_blank">daffodilvarsity.edu.bd</a>
            </span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
