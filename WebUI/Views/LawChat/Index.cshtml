@{
    ViewData["Title"] = "Law Assistant";
}

<style>
    .chat-container {
        max-width: 860px;
        margin: 0 auto;
    }

    .chat-box {
        height: 480px;
        overflow-y: auto;
        border: 1px solid #dee2e6;
        border-radius: 12px;
        padding: 20px;
        background: #f8f9fa;
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .message {
        max-width: 78%;
        padding: 12px 16px;
        border-radius: 16px;
        line-height: 1.5;
        font-size: 0.95rem;
        white-space: pre-wrap;
        word-break: break-word;
    }

        .message.user {
            align-self: flex-end;
            background: #0d6efd;
            color: white;
            border-bottom-right-radius: 4px;
        }

        .message.bot {
            align-self: flex-start;
            background: white;
            color: #212529;
            border: 1px solid #dee2e6;
            border-bottom-left-radius: 4px;
        }

        .message.typing {
            align-self: flex-start;
            background: white;
            border: 1px solid #dee2e6;
            border-bottom-left-radius: 4px;
            color: #6c757d;
            font-style: italic;
        }

    .input-area {
        margin-top: 16px;
        display: flex;
        gap: 10px;
    }

    #userInput {
        flex: 1;
        border-radius: 24px;
        padding: 10px 18px;
        border: 1px solid #ced4da;
        font-size: 0.95rem;
        outline: none;
        resize: none;
        height: 48px;
        overflow: hidden;
    }

    #sendBtn {
        border-radius: 24px;
        padding: 0 24px;
        font-weight: 500;
    }

    .header-badge {
        background: linear-gradient(135deg, #1a237e, #283593);
        color: white;
        border-radius: 14px;
        padding: 18px 24px;
        margin-bottom: 20px;
    }

    .model-info {
        font-size: 0.8rem;
        color: rgba(255,255,255,0.75);
        margin-top: 4px;
    }

    .quick-btn {
        font-size: 0.8rem;
        padding: 4px 12px;
        border-radius: 16px;
        white-space: nowrap;
    }
</style>

<div class="chat-container mt-4">
    <!-- Header -->
    <div class="header-badge d-flex align-items-center gap-3">
        <div style="font-size:2.2rem">⚖️</div>
        <div>
            <h4 class="mb-0 fw-bold">Law Student Assistant</h4>
            <div class="model-info">Powered by Ollama · Running locally on your machine</div>
        </div>
    </div>

    <!-- Quick prompts -->
    <div class="d-flex flex-wrap gap-2 mb-3">
        <button class="btn btn-outline-primary quick-btn" onclick="quickAsk('Explain the concept of mens rea in criminal law')">Mens Rea</button>
        <button class="btn btn-outline-primary quick-btn" onclick="quickAsk('What is the difference between civil law and criminal law?')">Civil vs Criminal</button>
        <button class="btn btn-outline-primary quick-btn" onclick="quickAsk('Explain the doctrine of precedent (stare decisis)')">Stare Decisis</button>
        <button class="btn btn-outline-primary quick-btn" onclick="quickAsk('What are the elements of a valid contract?')">Contract Elements</button>
        <button class="btn btn-outline-primary quick-btn" onclick="quickAsk('Explain habeas corpus')">Habeas Corpus</button>
    </div>

    <!-- Chat box -->
    <div class="chat-box" id="chatBox">
        <div class="message bot">
            👋 Hello! I'm your Law Assistant. I can help you understand legal concepts, case law, statutes, and more. Ask me anything — whether it's constitutional law, torts, contracts, criminal law, or legal procedure. What would you like to learn today?
        </div>
    </div>

    <!-- Input -->
    <div class="input-area">
        <textarea id="userInput" placeholder="Ask a legal question..." onkeydown="handleKey(event)"></textarea>
        <button class="btn btn-primary" id="sendBtn" onclick="sendMessage()">Send</button>
    </div>
    <div class="text-muted mt-2" style="font-size:0.78rem">
        ⚠️ This assistant is for educational purposes only and does not constitute legal advice.
    </div>
</div>

@section Scripts {
    <script>
            const OLLAMA_URL = "http://localhost:11434/api/generate";
            // Change this to the model you have pulled in Ollama, e.g. "llama3", "mistral", "gemma"
            const MODEL_NAME = "llama3.2";

                    const SYSTEM_PROMPT = `You are LexBot, the official AI assistant of the Department of Law at Daffodil International University (DIU), Bangladesh.

        You were built exclusively for DIU Law students and faculty. Your role is to:
        - Help DIU law students understand legal concepts, case law, and statutes
        - Focus on Bangladesh law, including the Constitution of Bangladesh, Penal Code, Evidence Act, Contract Act, Family laws, and other relevant legislation
        - Also cover general legal principles: criminal law, civil law, contracts, torts, constitutional law, and legal procedure
        - Reference Bangladesh Supreme Court and High Court Division judgments where relevant
        - Help students prepare for their DIU law exams and assignments
        - Always be encouraging, educational, and supportive of DIU students

        You only answer questions related to law and legal studies. If someone asks something unrelated to law, politely remind them that you are the DIU Department of Law assistant and can only help with legal topics.

        Always sign off responses by reminding students they can visit the DIU Department of Law for further academic support.`;

            let isGenerating = false;

            function handleKey(e) {
                if (e.key === 'Enter' && !e.shiftKey) {
                    e.preventDefault();
                    sendMessage();
                }
            }

            function quickAsk(text) {
                document.getElementById('userInput').value = text;
                sendMessage();
            }

            function appendMessage(role, text) {
                const box = document.getElementById('chatBox');
                const div = document.createElement('div');
                div.className = `message ${role}`;
                div.textContent = text;
                box.appendChild(div);
                box.scrollTop = box.scrollHeight;
                return div;
            }

            async function sendMessage() {
                if (isGenerating) return;

                const input = document.getElementById('userInput');
                const text = input.value.trim();
                if (!text) return;

                input.value = '';
                appendMessage('user', text);

                const typingDiv = appendMessage('typing', '⚖️ Thinking...');
                isGenerating = true;
                document.getElementById('sendBtn').disabled = true;

                try {
                    const response = await fetch(OLLAMA_URL, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            model: MODEL_NAME,
                            prompt: `${SYSTEM_PROMPT}\n\nStudent question: ${text}\n\nAnswer:`,
                            stream: true
                        })
                    });

                    if (!response.ok) {
                        throw new Error(`Ollama returned ${response.status}. Make sure Ollama is running and the model "${MODEL_NAME}" is pulled.`);
                    }

                    typingDiv.className = 'message bot';
                    typingDiv.textContent = '';

                    const reader = response.body.getReader();
                    const decoder = new TextDecoder();
                    let buffer = '';

                    while (true) {
                        const { done, value } = await reader.read();
                        if (done) break;

                        buffer += decoder.decode(value, { stream: true });
                        const lines = buffer.split('\n');
                        buffer = lines.pop(); // Keep incomplete line

                        for (const line of lines) {
                            if (!line.trim()) continue;
                            try {
                                const json = JSON.parse(line);
                                if (json.response) {
                                    typingDiv.textContent += json.response;
                                    document.getElementById('chatBox').scrollTop = document.getElementById('chatBox').scrollHeight;
                                }
                            } catch (e) { /* skip bad JSON */ }
                        }
                    }

                } catch (err) {
                    typingDiv.className = 'message bot';
                    typingDiv.textContent = `❌ Error: ${err.message}\n\nTips:\n• Make sure Ollama is running (ollama serve)\n• Make sure you have the model: ollama pull ${MODEL_NAME}\n• Check that port 11434 is accessible`;
                } finally {
                    isGenerating = false;
                    document.getElementById('sendBtn').disabled = false;
                }
            }
    </script>
}
